# Backend environment variables
# Copy this file to .env and update values for your environment

# PostgreSQL Database
DATABASE_URL=postgresql://sblr_user:sblr_password@localhost:5432/sblr1071_v2

# SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=noreply@lender.com
SENDER_PASSWORD=your-app-specific-password

# For development/testing:
# - Leave SMTP_SERVER as "smtp.example.com" to log emails to console instead
# - For production Gmail, use App Password (not regular password)

# Public URL of the frontend used in email links (MUST be reachable by the borrower)
# Local dev:    http://<your-machine-ip>:3000   (e.g. http://192.168.1.50:3000)
# Production:   https://1071.wahbank.com
# ngrok tunnel: https://xxxx.ngrok.io
FRONTEND_URL=http://localhost:3000
